{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "praxis",
  "identifier": "com.praxis.desktop",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dashboard/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev --prefix ../dashboard",
    "beforeBuildCommand": "npm run build --prefix ../dashboard"
  },
  "app": {
    "windows": [
      {
        "title": "praxis",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ivan-cavero/praxis/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
